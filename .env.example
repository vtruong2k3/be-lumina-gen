# App
PORT=3005
NODE_ENV=development
FRONTEND_URL=http://localhost:3005

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Security (generate strong random strings!)
JWT_SECRET=your_strong_jwt_secret_at_least_32_chars
JWT_REFRESH_SECRET=your_strong_refresh_secret_at_least_32_chars

# Google OAuth
# Create at: https://console.cloud.google.com/ > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_app.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3005/api/auth/google/callback

# External AI Services
CHAINHUB_API=https://api-banana.chainhub.tech/images/edits
CHAINHUB_API_KEY=sk-...
BASE_API=https://api.chainhub.tech/v1/images/generations
BASE_API_KEY=sk-...
CHAINHUB_GPT_URL=https://api.chainhub.tech/v1/chat/completions
